<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Two-Factor Authentication</title>
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
  <div class="card">
    <h1>Two-factor authentication</h1>
    <p class="subtitle">Enter the 6-digit code from your authenticator app.</p>

    <% if (errors.length) { %>
      <div class="alert alert-error">
        <% errors.forEach(function(e) { %>
          <div><%= e %></div>
        <% }) %>
      </div>
    <% } %>

    <form method="POST" action="/login/2fa" autocomplete="off">
      <label for="token">Authentication code</label>
      <input type="text" id="token" name="token" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus>

      <button type="submit">Verify</button>
    </form>

    <div class="secondary-link">
      <a href="/login">Cancel and log in as someone else</a>
    </div>
  </div>
</body>
</html>
